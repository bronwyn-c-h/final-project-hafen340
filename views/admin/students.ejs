<h1>All Students</h1>

<% if (students.length === 0) { %>
    <p>No students enrolled yet.</p>
<% } else { %>
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Date of Birth</th>
                <th>Parent</th>
                <th>Parent Email</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            <% students.forEach(student => { %>
                <tr>
                    <td><%= student.first_name %> <%= student.last_name %></td>
                    <td><%= student.date_of_birth ? new Date(student.date_of_birth).toLocaleDateString() : 'Not provided' %></td>
                    <td><%= student.parent_first_name %> <%= student.parent_last_name %></td>
                    <td><%= student.parent_email %></td>
                    <td><%= student.notes || 'None' %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
<% } %>