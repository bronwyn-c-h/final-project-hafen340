<h1>Manage Users</h1>

<% if (users.length === 0) { %>
    <p>No users yet.</p>
<% } else { %>
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(u => { %>
                <tr>
                    <td><%= u.first_name %> <%= u.last_name %></td>
                    <td><%= u.email %></td>
                    <td><%= u.role %></td>
                    <td><%= u.created_at.toLocaleDateString() %></td>
                    <td>
                        <a href="/admin/users/<%= u.id %>/edit">Edit Role</a>
                        <% if (u.id !== user.id) { %>
                            <form action="/admin/users/<%= u.id %>/delete" method="post" style="display:inline">
                                <button type="submit" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
<% } %>