<h1>Edit Session</h1>
<p>Date: <%= new Date(session.session_date).toLocaleDateString() %></p>
<p>Time: <%= session.slot_time %></p>

<% if (error) { %>
    <p style="color: red;"><%= error %></p>
<% } %>

<form action="/admin/sessions/<%= session.id %>/edit" method="post">
    <p>
        <label for="support_tutor_id">Support Tutor:</label>
        <select id="support_tutor_id" name="support_tutor_id">
            <option value="">Unassigned</option>
            <% tutors.forEach(tutor => { %>
                <option value="<%= tutor.id %>" 
                    <%= session.support_tutor_id === tutor.id ? 'selected' : '' %>>
                    <%= tutor.first_name %> <%= tutor.last_name %>
                </option>
            <% }) %>
        </select>
    </p>
    <p>
        <label for="status">Status:</label>
        <select id="status" name="status" required>
            <option value="scheduled" <%= session.status === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
            <option value="in_progress" <%= session.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
            <option value="completed" <%= session.status === 'completed' ? 'selected' : '' %>>Completed</option>
            <option value="cancelled" <%= session.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
        </select>
    </p>
    <p class="button">
        <button type="submit">Update Session</button>
    </p>
    <a href="/admin/sessions">Cancel</a>
</form>