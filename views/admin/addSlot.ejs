<h1>Add Slot - <%= semester.name %></h1>
<% if (error) { %>
    <p style="color: red;"><%= error %></p>
<% } %>
<form action="/admin/semesters/<%= semester.id %>/slots/add" method="post">
    <p>
        <label for="day_of_week">Day of Week:</label>
        <select id="day_of_week" name="day_of_week" required>
            <option value="Monday">Monday</option>
            <option value="Tuesday">Tuesday</option>
            <option value="Wednesday">Wednesday</option>
            <option value="Thursday">Thursday</option>
            <option value="Friday">Friday</option>
        </select>
    </p>
    <p>
        <label for="slot_time">Time:</label>
        <select id="slot_time" name="slot_time" required>
            <option value="15:00">3:00 PM</option>
            <option value="15:45">3:45 PM</option>
            <option value="16:30">4:30 PM</option>
        </select>
    </p>
    <p>
        <label for="max_students">Max Students:</label>
        <input type="number" id="max_students" name="max_students" value="2" min="1" max="3"/>
    </p>
    <p class="button">
        <button type="submit">Add Slot</button>
    </p>
</form>