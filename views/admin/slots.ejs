<h1>Session Slots - <%= semester.name %></h1>
<a href="/admin/semesters/<%= semester.id %>/slots/add">Add Slot</a>
<a href="/admin/semesters">Back to Semesters</a>

<% if (slots.length === 0) { %>
    <p>No slots yet.</p>
<% } else { %>
    <% slots.forEach(slot => { %>
        <div>
            <h2><%= slot.day_of_week %> at <%= new Date('1970-01-01T' + slot.slot_time).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) %></h2>
            <p>Max Students: <%= slot.max_students %></p>
            <p>Status: <%= slot.is_active ? 'Active' : 'Inactive' %></p>
        </div>
    <% }) %>
<% } %>